{
    "status": "buka",
    "periode": "Pendaftaran Diksar XV - Agustus 2026",
    "info_lanjutan": "Kuota terbatas! Segera daftar sebelum kuota penuh.",
    "link_form": "https://docs.google.com/forms/d/e/1FAIpQLSezoR4edTYzutC1CJAGrR6QU9CjZLRgURHjXjsJCiEVUuz64w/viewform?usp=publish-editor"
}
// Ganti bagian fetch('status.json') dengan ini:
fetch('https://docs.google.com/spreadsheets/d/13LJ21xL-7ZOiGZmqwlRSur7BuiYwQhZou0VqYuh4vlk/edit?usp=sharing')
    .then(response => response.text())
    .then(csv => {
        // Parse CSV sederhana
        const rows = csv.split('\n');
        const headers = rows[0].split(',');
        const values = rows[1].split(',');
        
        const data = {
            status: values[0].trim(),
            periode: values[1].trim(),
            info_lanjutan: values[2].trim(),
            link_form: values[3].trim()
        };
        
        // Sisanya sama seperti kode sebelumnya
        const container = document.getElementById('statusContainer');
        
        if (data.status === 'buka') {
            container.innerHTML = `
                <div class="status-box status-buka">
                    <div class="status-icon"><i class="fas fa-door-open"></i></div>
                    <h2 style="color: #155724;">PENDAFTARAN DIBUKA! 🎉</h2>
                    <div class="info-periode">
                        <i class="fas fa-calendar-alt"></i> ${data.periode}
                    </div>
                    <p style="margin-top: 1.5rem; color: #155724;">
                        Ayo bergabung bersama keluarga besar Mapatek Abhipraya!<br>
                        Isi formulir pendaftaran dengan klik tombol di bawah ini.
                    </p>
                    <a href="${data.link_form}" target="_blank" class="btn-daftar">
                        <i class="fas fa-pen-to-square"></i> DAFTAR SEKARANG
                    </a>
                </div>
            `;
        } else {
            container.innerHTML = `
                <div class="status-box status-tutup">
                    <div class="status-icon"><i class="fas fa-door-closed"></i></div>
                    <h2 style="color: #721c24;">PENDAFTARAN DITUTUP</h2>
                    <p style="margin-top: 1rem; color: #721c24; font-size: 1.1rem;">
                        ${data.info_lanjutan}
                    </p>
                    <div class="info-periode" style="background: #f8d7da; color: #721c24;">
                        <i class="fas fa-info-circle"></i> ${data.periode}
                    </div>
                </div>
            `;
        }
    })
    .catch(error => {
        console.error('Error:', error);
    });
